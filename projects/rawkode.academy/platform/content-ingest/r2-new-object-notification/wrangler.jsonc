{
  "name": "rawkode-academy-content-ingest",
  "main": "src/index.ts",
  "compatibility_date": "2024-03-29",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "queues": {
    "consumers": [
      {
        "queue": "rawkode-academy-content-ingest",
        "max_batch_size": 100,
        "max_batch_timeout": 5
      }
    ]
  }
}
